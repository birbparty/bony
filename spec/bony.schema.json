{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony.schema.json",
  "title": "bony",
  "description": "Generated from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path"
      }
    },
    "pathAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathAttachment"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "deformers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deformerRecord"
      }
    }
  },
  "required": [
    "skeleton",
    "bones"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "x": {
          "type": "number",
          "default": 0.0
        },
        "y": {
          "type": "number",
          "default": 0.0
        },
        "rotation": {
          "type": "number",
          "default": 0.0
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "shearX": {
          "type": "number",
          "default": 0.0
        },
        "shearY": {
          "type": "number",
          "default": 0.0
        },
        "inheritRotation": {
          "type": "boolean",
          "default": true
        },
        "inheritScale": {
          "type": "boolean",
          "default": true
        },
        "inheritReflection": {
          "type": "boolean",
          "default": true
        },
        "transformMode": {
          "type": "string",
          "enum": [
            "normal",
            "onlyTranslation",
            "noRotationOrReflection",
            "noScale",
            "noScaleOrReflection"
          ],
          "default": "normal"
        }
      },
      "required": [
        "name"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "normal"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": []
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritReflection"
            ]
          }
        }
      ]
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "attachment": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "bone",
        "name"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "height",
        "name",
        "width"
      ]
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        }
      },
      "required": [
        "bone",
        "name",
        "path",
        "target"
      ]
    },
    "pathAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "p0x": {
          "type": "number"
        },
        "p0y": {
          "type": "number"
        },
        "p1x": {
          "type": "number"
        },
        "p1y": {
          "type": "number"
        },
        "p2x": {
          "type": "number"
        },
        "p2y": {
          "type": "number"
        },
        "p3x": {
          "type": "number"
        },
        "p3y": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "p0x",
        "p0y",
        "p1x",
        "p1y",
        "p2x",
        "p2y",
        "p3x",
        "p3y"
      ]
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "default": {
          "type": "number",
          "default": 0.0
        }
      },
      "required": [
        "name",
        "min",
        "max"
      ]
    },
    "deformerRecord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "kind": {
          "type": "string",
          "enum": ["warp", "rotation"]
        },
        "warp": {
          "$ref": "#/$defs/warpLattice"
        },
        "rotation": {
          "$ref": "#/$defs/rotationDeformer"
        },
        "keyformBlend": {
          "$ref": "#/$defs/keyformBlend"
        }
      },
      "required": [
        "id",
        "kind"
      ]
    },
    "warpLattice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 2,
          "default": 2
        },
        "cols": {
          "type": "integer",
          "minimum": 2,
          "default": 2
        },
        "minX": {
          "type": "number"
        },
        "minY": {
          "type": "number"
        },
        "maxX": {
          "type": "number"
        },
        "maxY": {
          "type": "number"
        },
        "controlPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deformerPoint"
          }
        }
      },
      "required": [
        "minX",
        "minY",
        "maxX",
        "maxY",
        "controlPoints"
      ]
    },
    "rotationDeformer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pivotX": {
          "type": "number"
        },
        "pivotY": {
          "type": "number"
        },
        "angleDegrees": {
          "type": "number"
        },
        "scaleX": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.0
        },
        "opacity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 1.0
        }
      },
      "required": [
        "pivotX",
        "pivotY",
        "angleDegrees"
      ]
    },
    "deformerPoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ]
    },
    "keyformBlend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "axes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "keyforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/keyform"
          }
        }
      },
      "required": [
        "axes",
        "keyforms"
      ]
    },
    "keyform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coordinates": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        }
      },
      "required": [
        "coordinates",
        "values"
      ]
    }
  }
}
