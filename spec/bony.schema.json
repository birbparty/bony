{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony.schema.json",
  "title": "bony JSON",
  "description": "Generated canonical .bony JSON schema from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "pointAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pointAttachment"
      }
    },
    "boundingBoxAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/boundingBoxAttachment"
      }
    },
    "clippingAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clippingAttachment"
      }
    },
    "meshAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/meshAttachment"
      }
    },
    "deformTimelines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deformTimeline"
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path"
      }
    },
    "pathAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathAttachment"
      }
    },
    "ikConstraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ikConstraint"
      }
    },
    "transformConstraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/transformConstraint"
      }
    },
    "physicsConstraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/physicsConstraint"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "deformers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deformer"
      }
    },
    "animations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/animationClip"
      }
    },
    "eventTimelines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/eventTimeline"
      }
    },
    "stateMachines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachine"
      }
    },
    "skins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skin"
      },
      "minItems": 1,
      "contains": {
        "type": "object",
        "properties": {
          "name": {
            "const": "default"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  },
  "required": [
    "skeleton",
    "bones"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "x": {
          "type": "number",
          "default": 0.0
        },
        "y": {
          "type": "number",
          "default": 0.0
        },
        "rotation": {
          "type": "number",
          "default": 0.0
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "shearX": {
          "type": "number",
          "default": 0.0
        },
        "shearY": {
          "type": "number",
          "default": 0.0
        },
        "inheritRotation": {
          "type": "boolean",
          "default": true
        },
        "inheritScale": {
          "type": "boolean",
          "default": true
        },
        "inheritReflection": {
          "type": "boolean",
          "default": true
        },
        "transformMode": {
          "type": "string",
          "enum": [
            "normal",
            "onlyTranslation",
            "noRotationOrReflection",
            "noScale",
            "noScaleOrReflection"
          ],
          "default": "normal"
        }
      },
      "required": [
        "name"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "normal"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": []
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritReflection"
            ]
          }
        }
      ]
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "attachment": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "bone",
        "name"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "height",
        "name",
        "width"
      ]
    },
    "pointAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "rotation": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "rotation",
        "x",
        "y"
      ]
    },
    "boundingBoxAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "vertices": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "number"
          }
        }
      },
      "required": [
        "name",
        "vertices"
      ]
    },
    "clippingAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "vertices": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "number"
          }
        },
        "untilSlot": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "name",
        "vertices"
      ]
    },
    "meshAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "weighted": {
          "type": "boolean",
          "default": false
        },
        "vertices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  }
                },
                "required": [
                  "x",
                  "y"
                ]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "influences": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "bone": {
                          "type": "string",
                          "minLength": 1
                        },
                        "bindX": {
                          "type": "number"
                        },
                        "bindY": {
                          "type": "number"
                        },
                        "weight": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "bindX",
                        "bindY",
                        "bone",
                        "weight"
                      ]
                    }
                  }
                },
                "required": [
                  "influences"
                ]
              }
            ]
          }
        },
        "uvs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "description": "Flat [u0, v0, u1, v1, ...] pairs; each coordinate is unit-range 0..1; length is even and matches the vertex count (loader-validated per docs/mesh-attachment-contract.md)."
        },
        "triangles": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Flat vertex-index triples; length is a multiple of 3 (loader-validated per docs/mesh-attachment-contract.md)."
        }
      },
      "required": [
        "name",
        "triangles",
        "uvs",
        "vertices"
      ]
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "position": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "translateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rotateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "bone",
        "name",
        "path",
        "target"
      ]
    },
    "ikConstraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "target": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "mix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "bendPositive": {
          "type": "boolean",
          "default": true
        }
      },
      "required": [
        "bones",
        "name",
        "target"
      ]
    },
    "transformConstraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "translateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rotateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "scaleMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "shearMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "bone",
        "name",
        "target"
      ]
    },
    "physicsConstraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "channels": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31
        },
        "inertia": {
          "type": "number"
        },
        "strength": {
          "type": "number"
        },
        "damping": {
          "type": "number"
        },
        "mass": {
          "type": "number",
          "minimum": 0
        },
        "gravity": {
          "type": "number"
        },
        "wind": {
          "type": "number"
        },
        "physicsMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "bone",
        "channels",
        "name"
      ]
    },
    "pathAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "p0x": {
          "type": "number"
        },
        "p0y": {
          "type": "number"
        },
        "p1x": {
          "type": "number"
        },
        "p1y": {
          "type": "number"
        },
        "p2x": {
          "type": "number"
        },
        "p2y": {
          "type": "number"
        },
        "p3x": {
          "type": "number"
        },
        "p3y": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "p0x",
        "p0y",
        "p1x",
        "p1y",
        "p2x",
        "p2y",
        "p3x",
        "p3y"
      ]
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "default": {
          "type": "number",
          "default": 0.0
        }
      },
      "required": [
        "max",
        "min",
        "name"
      ]
    },
    "deformer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "kind": {
          "type": "string",
          "enum": [
            "warp",
            "rotation"
          ]
        },
        "warp": {
          "$ref": "#/$defs/warpLattice"
        },
        "rotation": {
          "$ref": "#/$defs/rotationDeformer"
        },
        "keyformBlend": {
          "$ref": "#/$defs/keyformBlend"
        }
      },
      "required": [
        "id",
        "kind"
      ]
    },
    "warpLattice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 0
        },
        "cols": {
          "type": "integer",
          "minimum": 0
        },
        "minX": {
          "type": "number"
        },
        "minY": {
          "type": "number"
        },
        "maxX": {
          "type": "number"
        },
        "maxY": {
          "type": "number"
        },
        "controlPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/deformerPoint"
          }
        }
      },
      "required": [
        "cols",
        "controlPoints",
        "maxX",
        "maxY",
        "minX",
        "minY",
        "rows"
      ]
    },
    "rotationDeformer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pivotX": {
          "type": "number"
        },
        "pivotY": {
          "type": "number"
        },
        "angleDegrees": {
          "type": "number"
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "opacity": {
          "type": "number",
          "default": 1.0
        }
      },
      "required": [
        "angleDegrees",
        "pivotX",
        "pivotY"
      ]
    },
    "keyformBlend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "axes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "keyforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/keyform"
          }
        }
      },
      "required": [
        "axes",
        "keyforms"
      ]
    },
    "keyform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coordinates": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        }
      },
      "required": [
        "coordinates",
        "values"
      ]
    },
    "animationClip": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "boneTimelines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/boneTimeline"
          },
          "default": []
        },
        "slotTimelines": {
