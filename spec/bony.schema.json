{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony.schema.json",
  "title": "bony",
  "description": "Generated from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    }
  },
  "required": [
    "skeleton",
    "bones"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "x": {
          "type": "number",
          "default": 0.0
        },
        "y": {
          "type": "number",
          "default": 0.0
        },
        "rotation": {
          "type": "number",
          "default": 0.0
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "shearX": {
          "type": "number",
          "default": 0.0
        },
        "shearY": {
          "type": "number",
          "default": 0.0
        },
        "inheritRotation": {
          "type": "boolean",
          "default": true
        },
        "inheritScale": {
          "type": "boolean",
          "default": true
        },
        "inheritReflection": {
          "type": "boolean",
          "default": true
        },
        "transformMode": {
          "type": "string",
          "enum": [
            "normal",
            "onlyTranslation",
            "noRotationOrReflection",
            "noScale",
            "noScaleOrReflection"
          ],
          "default": "normal"
        }
      },
      "required": [
        "name"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "normal"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": []
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritReflection"
            ]
          }
        }
      ]
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "attachment": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "bone",
        "name"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "height",
        "name",
        "width"
      ]
    }
  }
}
