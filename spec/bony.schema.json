{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony.schema.json",
  "title": "bony",
  "description": "Generated from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    }
  },
  "required": [
    "skeleton",
    "bones"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
