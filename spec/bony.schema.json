{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony.schema.json",
  "title": "bony",
  "description": "Generated from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    }
  },
  "required": [
    "skeleton",
    "bones",
    "slots",
    "regions"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "x": {
          "type": "number",
          "default": 0.0
        },
        "y": {
          "type": "number",
          "default": 0.0
        },
        "rotation": {
          "type": "number",
          "default": 0.0
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "shearX": {
          "type": "number",
          "default": 0.0
        },
        "shearY": {
          "type": "number",
          "default": 0.0
        },
        "inheritRotation": {
          "type": "boolean",
          "default": true
        },
        "inheritScale": {
          "type": "boolean",
          "default": true
        },
        "inheritReflection": {
          "type": "boolean",
          "default": true
        },
        "transformMode": {
          "type": "string",
          "default": "normal"
        }
      },
      "required": [
        "name"
      ]
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "attachment": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "bone",
        "name"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      },
      "required": [
        "height",
        "name",
        "width"
      ]
    }
  }
}
