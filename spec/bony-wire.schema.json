{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony-wire.schema.json",
  "title": "bony wire registry objects",
  "description": "Generated flat registry-object schema from registry/wire.yml and spec/defaults.yml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skeleton": {
      "$ref": "#/$defs/skeleton"
    },
    "bones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bone"
      }
    },
    "slots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slot"
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path"
      }
    },
    "pathAttachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathAttachment"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "deformers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/deformer"
      }
    },
    "warpLattices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warpLattice"
      }
    },
    "rotationDeformers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rotationDeformer"
      }
    },
    "keyformBlends": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keyformBlend"
      }
    },
    "keyforms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keyform"
      }
    },
    "animationClips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/animationClip"
      }
    },
    "boneTimelines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/boneTimeline"
      }
    },
    "slotTimelines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/slotTimeline"
      }
    },
    "stateMachines": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachine"
      }
    },
    "stateMachineInputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineInput"
      }
    },
    "stateMachineLayers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineLayer"
      }
    },
    "stateMachineStates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineState"
      }
    },
    "stateMachineBlendClips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineBlendClip"
      }
    },
    "stateMachineTransitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineTransition"
      }
    },
    "stateMachineConditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineCondition"
      }
    },
    "stateMachineListeners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateMachineListener"
      }
    }
  },
  "required": [
    "skeleton",
    "bones"
  ],
  "$defs": {
    "skeleton": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "default": "0.1.0"
        }
      },
      "required": [
        "name"
      ]
    },
    "bone": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "x": {
          "type": "number",
          "default": 0.0
        },
        "y": {
          "type": "number",
          "default": 0.0
        },
        "rotation": {
          "type": "number",
          "default": 0.0
        },
        "scaleX": {
          "type": "number",
          "default": 1.0
        },
        "scaleY": {
          "type": "number",
          "default": 1.0
        },
        "shearX": {
          "type": "number",
          "default": 0.0
        },
        "shearY": {
          "type": "number",
          "default": 0.0
        },
        "inheritRotation": {
          "type": "boolean",
          "default": true
        },
        "inheritScale": {
          "type": "boolean",
          "default": true
        },
        "inheritReflection": {
          "type": "boolean",
          "default": true
        },
        "transformMode": {
          "type": "string",
          "enum": [
            "normal",
            "onlyTranslation",
            "noRotationOrReflection",
            "noScale",
            "noScaleOrReflection"
          ],
          "default": "normal"
        }
      },
      "required": [
        "name"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "normal"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": []
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "onlyTranslation"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritRotation",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noRotationOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritScale"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScale"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          },
          "then": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritScale",
              "inheritReflection"
            ]
          },
          "then": {
            "properties": {
              "transformMode": {
                "const": "noScaleOrReflection"
              }
            },
            "required": [
              "transformMode"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": false
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation",
              "inheritScale"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": false
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": true
              }
            },
            "required": [
              "inheritRotation"
            ]
          }
        },
        {
          "not": {
            "properties": {
              "inheritRotation": {
                "const": true
              },
              "inheritScale": {
                "const": true
              },
              "inheritReflection": {
                "const": false
              }
            },
            "required": [
              "inheritReflection"
            ]
          }
        }
      ]
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "attachment": {
          "type": "string",
          "default": ""
        }
      },
      "required": [
        "bone",
        "name"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "height",
        "name",
        "width"
      ]
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bone": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "default": 0
        },
        "position": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "translateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rotateMix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "bone",
        "name",
        "path",
        "target"
      ]
    },
    "pathAttachment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "p0x": {
          "type": "number"
        },
        "p0y": {
          "type": "number"
        },
        "p1x": {
          "type": "number"
        },
        "p1y": {
          "type": "number"
        },
        "p2x": {
          "type": "number"
        },
        "p2y": {
          "type": "number"
        },
        "p3x": {
          "type": "number"
        },
        "p3y": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "p0x",
        "p0y",
        "p1x",
        "p1y",
        "p2x",
        "p2y",
        "p3x",
        "p3y"
      ]
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "parameterMin": {
          "type": "number"
        },
        "parameterMax": {
          "type": "number"
        },
        "parameterDefault": {
          "type": "number",
          "default": 0.0
        }
      },
      "required": [
        "name",
        "parameterMax",
        "parameterMin"
      ]
    },
    "deformer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deformerId": {
          "type": "string"
        },
        "parent": {
          "type": "string",
          "default": ""
        },
        "deformerOrder": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "deformerKind": {
          "type": "string"
        }
      },
      "required": [
        "deformerId",
        "deformerKind"
      ]
    },
    "warpLattice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "warpRows": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "warpCols": {
          "type": "integer",
          "minimum": 0,
          "default": 2
        },
        "warpMinX": {
          "type": "number"
        },
        "warpMinY": {
          "type": "number"
        },
        "warpMaxX": {
          "type": "number"
        },
        "warpMaxY": {
          "type": "number"
        },
        "warpControlPoints": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "required": [
        "warpControlPoints",
        "warpMaxX",
        "warpMaxY",
        "warpMinX",
        "warpMinY"
      ]
    },
    "rotationDeformer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rotationPivotX": {
          "type": "number"
        },
        "rotationPivotY": {
          "type": "number"
        },
        "rotationAngleDegrees": {
          "type": "number"
        },
        "rotationScaleX": {
          "type": "number",
          "default": 1.0
        },
        "rotationScaleY": {
          "type": "number",
          "default": 1.0
        },
        "rotationOpacity": {
          "type": "number",
          "default": 1.0
        }
      },
      "required": [
        "rotationAngleDegrees",
        "rotationPivotX",
        "rotationPivotY"
      ]
    },
    "keyformBlend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blendValueCount": {
          "type": "integer",
          "minimum": 0
        },
        "blendAxes": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "required": [
        "blendAxes",
        "blendValueCount"
      ]
    },
    "keyform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blendCoordinates": {
          "type": "string",
          "contentEncoding": "base64"
        },
        "blendValues": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "required": [
        "blendCoordinates",
        "blendValues"
      ]
    },
    "animationClip": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name"
      ]
    },
    "boneTimeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "boneIndex": {
          "type": "integer",
          "minimum": 0
        },
        "boneTimelineKind": {
          "type": "integer",
          "minimum": 0
        },
        "timelineKeys": {
          "type": "string",
          "contentEncoding": "base64",
          "x-bony-packedBytes": {
            "payload": "animationTimelineKeys",
            "layout": "docs/binary-animation-state-machine-object-families.md#keyframe-payloads",
            "structuralSchema": "base64Only",
            "validatedBy": "loader"
          }
        }
      },
      "required": [
        "boneIndex",
        "boneTimelineKind",
        "timelineKeys"
      ]
    },
    "slotTimeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slotIndex": {
          "type": "integer",
          "minimum": 0
        },
        "slotTimelineKind": {
          "type": "integer",
          "minimum": 0
        },
        "timelineKeys": {
          "type": "string",
          "contentEncoding": "base64",
          "x-bony-packedBytes": {
            "payload": "animationTimelineKeys",
            "layout": "docs/binary-animation-state-machine-object-families.md#keyframe-payloads",
            "structuralSchema": "base64Only",
            "validatedBy": "loader"
          }
        }
      },
      "required": [
        "slotIndex",
        "slotTimelineKind",
        "timelineKeys"
      ]
    },
    "stateMachine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name"
      ]
    },
    "stateMachineInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "stateMachineInputKind": {
          "type": "integer",
          "minimum": 0
        },
        "inputDefaultBool": {
          "type": "boolean"
        },
        "inputDefaultNumber": {
          "type": "number"
        }
      },
      "required": [
        "name",
        "stateMachineInputKind"
      ]
    },
    "stateMachineLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "initialStateIndex": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "required": [
        "name"
      ]
    },
    "stateMachineState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "stateMachineStateKind": {
          "type": "integer",
          "minimum": 0
        },
        "stateClipIndex": {
          "type": "integer",
          "minimum": 0
        },
        "stateLoop": {
          "type": "boolean"
        },
        "stateBlendInputIndex": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "name",
        "stateMachineStateKind"
      ]
    },
    "stateMachineBlendClip": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blendClipAnimationIndex": {
          "type": "integer",
          "minimum": 0
        },
        "blendClipValue": {
          "type": "number"
        },
        "blendClipLoop": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "blendClipAnimationIndex",
        "blendClipValue"
      ]
    },
    "stateMachineTransition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transitionFromStateIndex": {
          "type": "integer",
          "minimum": 0
        },
        "transitionToStateIndex": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "transitionFromStateIndex",
        "transitionToStateIndex"
      ]
    },
    "stateMachineCondition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "conditionInputIndex": {
          "type": "integer",
          "minimum": 0
        },
        "stateMachineConditionKind": {
          "type": "integer",
          "minimum": 0
        },
        "conditionBoolValue": {
          "type": "boolean"
        },
        "conditionNumberValue": {
          "type": "number"
        }
      },
      "required": [
        "conditionInputIndex",
        "stateMachineConditionKind"
      ]
    },
    "stateMachineListener": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "stateMachineListenerKind": {
          "type": "integer",
          "minimum": 0
        },
        "listenerLayerIndex": {
          "type": "integer",
          "minimum": 0
        },
        "listenerFromStateIndex": {
          "type": "integer",
          "minimum": 0
        },
        "listenerToStateIndex": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "listenerLayerIndex",
        "name",
        "stateMachineListenerKind"
      ]
    }
  }
}
