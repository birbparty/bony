{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bony.local/spec/bony-atlas.schema.json",
  "title": "bony atlas metadata",
  "description": "Output of 'bony pack-atlas'. Describes how source images were packed into atlas page(s).",
  "type": "object",
  "required": ["format", "pageSize", "padding", "pages", "regions"],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "const": "bony.atlas.v1",
      "description": "Format identifier — always 'bony.atlas.v1'."
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1,
      "description": "Side length in pixels of each (square) atlas page."
    },
    "padding": {
      "type": "integer",
      "minimum": 0,
      "description": "Per-region padding in pixels added around each image during packing."
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "width", "height"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Filename of the atlas page PNG (relative to the atlas JSON)."
          },
          "width": {
            "type": "integer",
            "minimum": 1,
            "description": "Page width in pixels."
          },
          "height": {
            "type": "integer",
            "minimum": 1,
            "description": "Page height in pixels."
          }
        }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "page", "x", "y", "width", "height", "u0", "v0", "u1", "v1"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Region name (source image basename without extension)."
          },
          "page": {
            "type": "integer",
            "minimum": 0,
            "description": "Zero-based index into the pages array."
          },
          "x": {
            "type": "integer",
            "minimum": 0,
            "description": "Left edge of the region within the page, in pixels."
          },
          "y": {
            "type": "integer",
            "minimum": 0,
            "description": "Top edge of the region within the page, in pixels."
          },
          "width": {
            "type": "integer",
            "minimum": 1,
            "description": "Region width in pixels."
          },
          "height": {
            "type": "integer",
            "minimum": 1,
            "description": "Region height in pixels."
          },
          "u0": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Left UV coordinate (x / pageWidth)."
          },
          "v0": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Top UV coordinate (y / pageHeight). Image-space Y-down: v=0 is the top edge."
          },
          "u1": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Right UV coordinate ((x + width) / pageWidth)."
          },
          "v1": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Bottom UV coordinate ((y + height) / pageHeight). Image-space Y-down: v=1 is the bottom edge."
          }
        }
      }
    }
  }
}
